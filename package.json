{
  "name": "readme-editor",
  "displayName": "Readme Editor",
  "description": "Live preview & HTML editor for Markdown files — see changes in real time",
  "version": "1.0.0",
  "publisher": "RishabhRanjan",
  "author": {
    "name": "Rishabh Ranjan"
  },
  "license": "MIT",
  "keywords": [
    "markdown",
    "readme",
    "preview",
    "html",
    "live preview",
    "editor",
    "md"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Var6/readme-editor"
  },
  "bugs": {
    "url": "https://github.com/Var6/readme-editor/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "readmeLivePreview.openPreview",
        "title": "Open Readme Editor",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "readmeLivePreview.openPreview",
          "when": "resourceExtname == .md || editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "readmeLivePreview.openPreview",
          "when": "resourceExtname == .md || editorLangId == markdown"
        }
      ]
    },
    "keybindings": [
      {
        "command": "readmeLivePreview.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .md || editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  }
}
